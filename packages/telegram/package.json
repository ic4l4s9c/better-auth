{
  "name": "@better-auth/telegram",
  "version": "0.3.2",
  "type": "module",
  "description": "Telegram authentication plugin for Better Auth",
  "main": "./dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-auth/better-auth",
    "directory": "packages/telegram"
  },
  "homepage": "https://github.com/vcode-sh/better-auth-telegram#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ]
    }
  },
  "keywords": [
    "better-auth",
    "telegram",
    "authentication",
    "plugin",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.json"
  },
  "author": "Vibe Code <hello@vcode.sh> (https://vcode.sh)",
  "peerDependencies": {
    "better-auth": "^1.0.0"
  },
  "devDependencies": {
    "better-auth": "workspace:*",
    "tsdown": "catalog:"
  },
  "dependencies": {
    "@better-auth/utils": "0.3.0"
  },
  "files": [
    "dist"
  ]
}
